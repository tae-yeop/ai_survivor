---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/post/Breadcrumbs.astro';
import { buildPageSeo } from '../lib/seo';

// Update the email below before launch — and any other channels you want to expose.
const CONTACT_EMAIL = 'contact@example.com';

const seo = buildPageSeo({
  title: 'Contact',
  description: '제안, 정정 요청, 협업 문의를 보낼 수 있는 연락처.',
  path: '/contact/',
});
---

<BaseLayout seo={seo}>
  <article class="container-prose py-12">
    <div class="mb-6"><Breadcrumbs items={[{ href: '/', label: 'Home' }, { label: 'Contact' }]} /></div>
    <h1 class="text-3xl font-bold tracking-tight text-ink-900 sm:text-4xl">Contact</h1>
    <p class="mt-4 text-lg text-ink-500">
      글에 대한 정정, 글감 제안, 협업·강연·자문 문의를 환영한다.
    </p>

    <div class="prose prose-lg mt-8 max-w-none">
      <h2>이메일</h2>
      <p>
        <a href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a>
      </p>

      <h2>응답 기준</h2>
      <ul>
        <li>본문 오류 정정 요청은 가능한 빨리 답한다.</li>
        <li>일반 협업 문의는 영업일 기준 3~5일 내 회신한다.</li>
        <li>광고·후원 제안은 글의 신뢰성을 해치지 않는 범위에서 검토한다.</li>
      </ul>

      <h2>요청 시 함께 보내주면 좋은 정보</h2>
      <ul>
        <li>본인/소속 간단 소개</li>
        <li>문의 배경과 목적</li>
        <li>참고 자료 또는 링크</li>
        <li>원하는 회신 기한이 있다면 함께</li>
      </ul>
    </div>
  </article>
</BaseLayout>
