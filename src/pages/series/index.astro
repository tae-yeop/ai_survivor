---
import ListLayout from '../../layouts/ListLayout.astro';
import { getAllPosts, postUrl } from '../../lib/posts';
import { seriesBuckets } from '../../lib/taxonomy';
import { seriesLabel } from '../../lib/labels';
import { buildPageSeo } from '../../lib/seo';

const posts = await getAllPosts();
const buckets = seriesBuckets(posts);

const seo = buildPageSeo({
  title: '시리즈',
  description: '여러 글을 묶어 단계적으로 따라갈 수 있는 시리즈 모음.',
  path: '/series/',
});
---

<ListLayout
  seo={seo}
  kicker="index · series"
  title="시리즈"
  description="여러 글을 묶어 처음부터 끝까지 따라갈 수 있는 연재 콘텐츠."
  breadcrumbs={[{ href: '/', label: 'Home' }, { label: 'Series' }]}
  count={buckets.length}
  countLabel="개"
>
  {buckets.length === 0 ? (
    <p class="font-mono text-sm text-ink-500 py-16 text-center border-y border-paper-rule tracking-wider uppercase">
      아직 시리즈가 없다.
    </p>
  ) : (
    <ul class="divide-hair">
      {buckets.map((s, i) => (
        <li class="grid gap-y-4 py-10 sm:grid-cols-[5rem_minmax(0,2fr)_minmax(0,3fr)] sm:gap-x-10">
          <p class="font-mono text-xs text-accent tabular-nums">SER · {String(i + 1).padStart(2, '0')}</p>
          <div>
            <a href={`/series/${s.slug}/`} class="block group">
              <h2 class="font-display text-3xl text-ink-800 leading-tight tracking-tightest group-hover:text-accent transition-colors">
                {seriesLabel(s.slug)}
              </h2>
              <p class="kicker mt-2 tabular-nums">전 {s.count}편</p>
            </a>
          </div>
          <ol class="list-none">
            {s.posts.slice(0, 4).map((p, idx) => (
              <li class="grid grid-cols-[2.5rem_1fr] gap-2 py-2 border-b border-paper-rule last:border-b-0">
                <span class="font-mono text-xs text-ink-400 tabular-nums">{String(idx + 1).padStart(2, '0')}</span>
                <a href={postUrl(p)} class="text-ink-700 hover:text-accent transition-colors line-clamp-1">
                  {p.data.title}
                </a>
              </li>
            ))}
          </ol>
        </li>
      ))}
    </ul>
  )}
</ListLayout>
