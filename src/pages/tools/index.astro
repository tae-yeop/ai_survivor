---
import ListLayout from '../../layouts/ListLayout.astro';
import { getAllPosts } from '../../lib/posts';
import { toolBuckets } from '../../lib/taxonomy';
import { buildPageSeo } from '../../lib/seo';

const posts = await getAllPosts();
const buckets = toolBuckets(posts);

const seo = buildPageSeo({
  title: '도구별 글 모음',
  description: '글에서 다룬 AI 도구별로 묶어 한 번에 탐색할 수 있다.',
  path: '/tools/',
});
---

<ListLayout
  seo={seo}
  title="도구별 글 모음"
  description="글에서 사용한 AI 도구·프레임워크별로 글을 묶어 보여준다."
  breadcrumbs={[{ href: '/', label: 'Home' }, { label: 'Tools' }]}
>
  {buckets.length === 0 ? (
    <p class="rounded border border-dashed border-ink-200 bg-ink-50 p-6 text-center text-sm text-ink-500">
      아직 도구 정보가 없습니다.
    </p>
  ) : (
    <ul class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {buckets.map((t) => (
        <li class="rounded-lg border border-ink-100 p-5">
          <a href={`/tools/${t.slug}/`} class="block">
            <p class="text-xs uppercase tracking-wide text-ink-500">도구 · 글 {t.count}편</p>
            <p class="mt-1 text-lg font-semibold text-ink-900 hover:underline">{t.label}</p>
          </a>
        </li>
      ))}
    </ul>
  )}
</ListLayout>
