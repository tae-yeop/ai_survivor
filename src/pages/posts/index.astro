---
import ListLayout from '../../layouts/ListLayout.astro';
import PostList from '../../components/post/PostList.astro';
import { getAllPosts } from '../../lib/posts';
import { categoryBuckets } from '../../lib/taxonomy';
import { categoryLabel } from '../../lib/labels';
import { buildPageSeo } from '../../lib/seo';

const posts = await getAllPosts();
const categories = categoryBuckets(posts);

const seo = buildPageSeo({
  title: '전체 글',
  description:
    'AI 도구, 바이브코딩, 업무 자동화, 생산성 실험을 다룬 모든 글을 최신순으로 모았다.',
  path: '/posts/',
});
---

<ListLayout
  seo={seo}
  kicker="archive · all dispatches"
  title="전체 기록"
  description="AI 도구, 바이브코딩, 업무 자동화 실험을 정리한 글을 최신순으로 보여준다."
  breadcrumbs={[{ href: '/', label: 'Home' }, { label: 'Posts' }]}
  count={posts.length}
>
  {categories.length > 0 && (
    <nav aria-label="카테고리" class="mb-10 flex flex-wrap items-center gap-2">
      <span class="kicker mr-2">filter</span>
      {categories.map((c) => (
        <a href={`/categories/${c.slug}/`} class="label-chip">
          <span>{categoryLabel(c.slug)}</span>
          <span class="text-accent tabular-nums">{String(c.count).padStart(2, '0')}</span>
        </a>
      ))}
    </nav>
  )}
  <PostList posts={posts} />
</ListLayout>
