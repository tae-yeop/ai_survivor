---
import ListLayout from '../../layouts/ListLayout.astro';
import PostList from '../../components/post/PostList.astro';
import { getAllPosts } from '../../lib/posts';
import { categoryBuckets } from '../../lib/taxonomy';
import { categoryLabel } from '../../lib/labels';
import { buildPageSeo } from '../../lib/seo';

const posts = await getAllPosts();
const categories = categoryBuckets(posts);

const seo = buildPageSeo({
  title: '전체 글',
  description:
    'AI 도구, 바이브코딩, 업무 자동화, 생산성 실험을 다룬 모든 글을 최신순으로 모았다.',
  path: '/posts/',
});
---

<ListLayout
  seo={seo}
  kicker="archive · all dispatches"
  title="전체 기록"
  description="AI 도구, 바이브코딩, 업무 자동화 실험을 정리한 글을 최신순으로 보여준다."
  breadcrumbs={[{ href: '/', label: 'Home' }, { label: 'Posts' }]}
  count={posts.length}
>
  {categories.length > 0 && (
    <nav aria-label="카테고리" class="mb-10 flex flex-wrap items-center gap-2">
      <span class="kicker mr-2">filter</span>
      {categories.map((c) => (
        <a href={`/categories/${c.slug}/`} class="label-chip">
          <span>{categoryLabel(c.slug)}</span>
          <span class="text-accent tabular-nums">{String(c.count).padStart(2, '0')}</span>
        </a>
      ))}
    </nav>
  )}
  <section class="mb-8 border-y border-paper-rule py-5" aria-labelledby="archive-search-heading">
    <div class="grid gap-4 md:grid-cols-[minmax(0,1fr)_auto] md:items-end">
      <div>
        <p id="archive-search-heading" class="kicker kicker-accent">archive search</p>
        <label for="post-search" class="mt-2 block font-display text-2xl text-ink-800 tracking-tight">
          필요한 실험 기록 찾기
        </label>
      </div>
      <p id="post-search-count" class="font-mono text-xs uppercase tracking-[0.12em] text-ink-400 tabular-nums">
        {posts.length} records
      </p>
    </div>
    <input
      id="post-search"
      type="search"
      autocomplete="off"
      placeholder="예: Cursor, AdSense, SEO, 문서화"
      class="mt-5 w-full border border-paper-rule bg-paper-elevated px-4 py-3 font-mono text-sm text-ink-800 placeholder:text-ink-300 focus:border-accent focus:outline-none"
    />
    <p id="post-search-empty" class="mt-4 hidden border border-dashed border-paper-rule p-5 text-sm leading-relaxed text-ink-500">
      맞는 글이 없습니다. 도구, 카테고리, 태그 키워드를 바꿔보세요.
    </p>
  </section>

  <PostList posts={posts} />
</ListLayout>

<script is:inline>
  (() => {
    const input = document.getElementById('post-search');
    const count = document.getElementById('post-search-count');
    const empty = document.getElementById('post-search-empty');
    const items = Array.from(document.querySelectorAll('[data-post-item]'));
    if (!input || !count || !empty || items.length === 0) return;

    function applyFilter() {
      const query = input.value.trim().toLowerCase();
      let visible = 0;
      items.forEach((item) => {
        const haystack = item.getAttribute('data-search') || '';
        const matches = query.length === 0 || haystack.includes(query);
        item.hidden = !matches;
        if (matches) visible += 1;
      });
      count.textContent = `${visible} / ${items.length} records`;
      empty.classList.toggle('hidden', visible !== 0);
    }

    input.addEventListener('input', applyFilter);
  })();
</script>
