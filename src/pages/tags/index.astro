---
import ListLayout from '../../layouts/ListLayout.astro';
import { getAllPosts } from '../../lib/posts';
import { tagBuckets } from '../../lib/taxonomy';
import { buildPageSeo } from '../../lib/seo';

const posts = await getAllPosts();
const buckets = tagBuckets(posts);

const seo = buildPageSeo({
  title: '태그',
  description: 'AI Vibe Lab의 글에 사용된 태그 목록과 각 태그별 글 수.',
  path: '/tags/',
});
---

<ListLayout
  seo={seo}
  kicker="index · tags"
  title="태그"
  description="글 본문에서 자주 다룬 도구, 워크플로우, 키워드를 모았다."
  breadcrumbs={[{ href: '/', label: 'Home' }, { label: 'Tags' }]}
  count={buckets.length}
  countLabel="개"
>
  {buckets.length === 0 ? (
    <p class="font-mono text-sm text-ink-500 py-16 text-center border-y border-paper-rule tracking-wider uppercase">
      아직 태그가 없다.
    </p>
  ) : (
    <ul class="flex flex-wrap gap-2">
      {buckets.map((b) => (
        <li>
          <a href={`/tags/${b.slug}/`} class="label-chip">
            <span class="text-accent">#</span>
            <span class="text-ink-800">{b.label}</span>
            <span class="tabular-nums text-ink-400">{String(b.count).padStart(2, '0')}</span>
          </a>
        </li>
      ))}
    </ul>
  )}
</ListLayout>
