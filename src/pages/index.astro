---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/post/PostCard.astro';
import { getAllPosts, postUrl } from '../lib/posts';
import { categoryBuckets, seriesBuckets, toolBuckets } from '../lib/taxonomy';
import { CATEGORY_DESCRIPTIONS, categoryLabel, seriesLabel } from '../lib/labels';
import { buildPageSeo } from '../lib/seo';
import { SITE_NAME, SITE_DESCRIPTION } from '../lib/site';
import { formatIso } from '../lib/dates';

const posts = await getAllPosts();
const lead = posts[0];
const restLatest = posts.slice(1, 6);
const seriesList = seriesBuckets(posts).slice(0, 3);
const categories = categoryBuckets(posts);
const tools = toolBuckets(posts).slice(0, 12);

const seo = buildPageSeo({
  title: SITE_NAME,
  description: SITE_DESCRIPTION,
  path: '/',
});

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE_NAME,
  url: seo.canonical,
  description: SITE_DESCRIPTION,
  inLanguage: 'ko-KR',
};

const today = new Date();
const todayIso = formatIso(today);
const todayLabel = `${today.getFullYear()}.${String(today.getMonth() + 1).padStart(2, '0')}.${String(today.getDate()).padStart(2, '0')}`;
---

<BaseLayout seo={seo} jsonLd={websiteJsonLd}>
  <!-- ============================================================
       § Lede — metadata bar + full-width headline + manifesto
       ============================================================ -->
  <section class="container-mast pt-10 sm:pt-16 pb-20 sm:pb-28">
    <!-- Metadata bar: kicker and issue stamp share same row/weight -->
    <div class="flex items-start justify-between gap-6">
      <p class="kicker">
        DISPATCH · <time datetime={todayIso} class="tabular-nums">{todayLabel}</time>
        · 한국어 / Korean Edition
      </p>
      <aside class="hidden sm:flex flex-col items-end gap-2 text-right shrink-0">
        <div class="border border-ink-800 px-3 py-2">
          <p class="kicker tabular-nums">총 기록</p>
          <p class="font-display text-4xl text-ink-800 tabular-nums leading-none mt-1">
            {String(posts.length).padStart(2, '0')}
          </p>
        </div>
        <p class="kicker">실험 / 실패 / 검증</p>
      </aside>
    </div>

    <!-- Hero headline — full width, character blur-stagger reveal -->
    <h1 class="char-mast mt-6 font-display text-mast text-ink-800 leading-[0.95] tracking-tightest">
      {'AI를 써본 결과를'.split('').map((ch, i) => (
        <span class="char" style={`--ci:${i}`}>{ch === ' ' ? ' ' : ch}</span>
      ))}
      <br />
      {'그대로 '.split('').map((ch, i) => (
        <span class="char" style={`--ci:${10 + i}`}>{ch}</span>
      ))}
      <span class="relative inline-block">
        <span class="relative z-10">
          {'기록'.split('').map((ch, i) => (
            <span class="char" style={`--ci:${14 + i}`}>{ch}</span>
          ))}
        </span>
        <span aria-hidden="true" class="char-accent-bar absolute inset-x-[-0.05em] bottom-[0.08em] h-[0.4em] bg-accent/45 -z-0"></span>
      </span>
      {'한다.'.split('').map((ch, i) => (
        <span class="char" style={`--ci:${16 + i}`}>{ch}</span>
      ))}
    </h1>

    <!-- Full-width rule anchors the headline -->
    <div class="rule-thick mt-10"></div>

    <!-- Manifesto + About: 2-col below the rule -->
    <div class="mt-10 grid gap-10 lg:grid-cols-[1.2fr_1fr] lg:gap-20 items-start">
      <blockquote
        class="border-l-2 border-accent pl-5 text-base sm:text-lg text-ink-600 leading-relaxed max-w-prose text-pretty"
        data-reveal="fade-up"
      >
        일반론이 아닌 환경, 시간, 비용, 실패, 사람이 수정한 부분까지 같이 적는다.
        AI 도구는 빠르게 바뀐다 — 결과만 남기면 6개월 뒤엔 거짓말이 된다.
      </blockquote>

      <div data-reveal="fade-up" data-reveal-delay="1">
        <p class="kicker">about</p>
        <p class="mt-3 text-ink-600 leading-relaxed">
          {SITE_DESCRIPTION}
        </p>
        <div class="mt-6 flex flex-wrap items-center gap-x-6 gap-y-3">
          <a
            href="/posts/"
            class="inline-flex items-center gap-2.5 bg-ink-800 text-paper px-5 py-3 font-mono text-[0.72rem] tracking-[0.12em] uppercase hover:bg-accent transition-colors"
          >
            전체 기록 읽기
            <span aria-hidden="true">→</span>
          </a>
          <a
            href="/about/"
            class="inline-flex items-center gap-2 font-mono text-[0.72rem] tracking-[0.12em] uppercase text-ink-700 hover:text-accent transition-colors border-b border-ink-300 hover:border-accent pb-0.5"
          >
            편집 원칙 보기
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       § 01 — LATEST DISPATCH — feature + numbered list
       ============================================================ -->
  <section class="container-mast pb-24">
    <header class="section-marker mb-8" data-reveal="fade-up">
      <p class="kicker tabular-nums">01 / 04</p>
      <h2 class="font-display text-3xl sm:text-4xl text-ink-800 tracking-tightest">최신 기록</h2>
      <span class="ml-auto hidden sm:block">
        <a href="/posts/" class="font-mono text-xs tracking-[0.12em] uppercase text-ink-500 hover:text-accent transition-colors">
          모두 보기 →
        </a>
      </span>
    </header>

    {posts.length === 0 ? (
      <p class="font-mono text-sm text-ink-500 py-16 text-center border-y border-paper-rule tracking-wider uppercase">
        아직 발행된 기록이 없다.
      </p>
    ) : (
      <div class="grid gap-x-12 lg:grid-cols-[1.4fr_1fr]">
        <!-- Featured post — full-width left column -->
        <div class="lg:border-r lg:border-paper-rule lg:pr-12">
          <p class="kicker mb-4">FEATURE / 이번 호 대표</p>
          {lead && <PostCard post={lead} variant="feature" />}
        </div>

        <!-- Right column — numbered runner-ups -->
        <ol class="list-none mt-10 lg:mt-0">
          <li class="kicker mb-3 block">RUNNERS UP</li>
          {restLatest.map((p, i) => (
            <li>
              <PostCard post={p} index={i + 2} />
            </li>
          ))}
        </ol>
      </div>
    )}
  </section>

  <!-- ============================================================
       § 02 — SERIES — table-like editorial listing
       ============================================================ -->
  {seriesList.length > 0 && (
    <section class="bg-paper-deep border-y border-paper-rule">
      <div class="container-mast py-20">
        <header class="section-marker mb-10" data-reveal="fade-up">
          <p class="kicker tabular-nums">02 / 04</p>
          <h2 class="font-display text-3xl sm:text-4xl text-ink-800 tracking-tightest">진행 중인 시리즈</h2>
          <span class="ml-auto hidden sm:block">
            <a href="/series/" class="font-mono text-xs tracking-[0.12em] uppercase text-ink-500 hover:text-accent transition-colors">
              전체 시리즈 →
            </a>
          </span>
        </header>

        <ul class="divide-hair">
          {seriesList.map((s, i) => (
            <li class="grid gap-y-4 py-8 sm:grid-cols-[5rem_minmax(0,2fr)_minmax(0,3fr)] sm:gap-x-8 group">
              <p class="font-mono text-xs text-accent tabular-nums">SER · {String(i + 1).padStart(2, '0')}</p>
              <div>
                <a href={`/series/${s.slug}/`} class="block group">
                  <p class="font-display text-2xl sm:text-3xl text-ink-800 leading-tight tracking-tight group-hover:text-accent transition-colors">
                    {seriesLabel(s.slug)}
                  </p>
                  <p class="kicker mt-2 tabular-nums">전 {s.count}편</p>
                </a>
              </div>
              <ol class="list-none">
                {s.posts.slice(0, 3).map((p, idx) => (
                  <li class="grid grid-cols-[2.5rem_1fr] py-1.5 border-b border-paper-rule last:border-b-0">
                    <span class="font-mono text-xs text-ink-400 tabular-nums">{String(idx + 1).padStart(2, '0')}</span>
                    <a href={postUrl(p)} class="text-ink-700 hover:text-accent transition-colors line-clamp-1">
                      {p.data.title}
                    </a>
                  </li>
                ))}
              </ol>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <!-- ============================================================
       § 03 — CATEGORY DOSSIERS
       ============================================================ -->
  <section class="container-mast py-24">
    <header class="section-marker mb-10" data-reveal="fade-up">
      <p class="kicker tabular-nums">03 / 04</p>
      <h2 class="font-display text-3xl sm:text-4xl text-ink-800 tracking-tightest">카테고리 별 기록</h2>
    </header>

    <div class="grid gap-12 lg:grid-cols-2 lg:gap-x-16">
      {categories.map((c, i) => (
        <article class="grid gap-3 pb-10 border-b border-paper-rule">
          <div class="flex items-baseline justify-between gap-4">
            <p class="kicker kicker-accent tabular-nums">CAT · {String(i + 1).padStart(2, '0')}</p>
            <p class="kicker tabular-nums">{c.count}편</p>
          </div>
          <h3 class="font-display text-3xl text-ink-800 leading-tight tracking-tightest">
            <a href={`/categories/${c.slug}/`} class="hover:text-accent transition-colors">
              {categoryLabel(c.slug)}
            </a>
          </h3>
          <p class="text-ink-500 leading-relaxed max-w-prose">
            {CATEGORY_DESCRIPTIONS[c.slug as keyof typeof CATEGORY_DESCRIPTIONS] ?? ''}
          </p>
          <ul class="mt-2 divide-hair">
            {c.posts.slice(0, 3).map((p) => (
              <li class="py-2.5">
                <a href={postUrl(p)} class="text-base text-ink-700 hover:text-accent transition-colors leading-snug block">
                  {p.data.title}
                </a>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <!-- ============================================================
       § 04 — TOOL INDEX — chip cloud
       ============================================================ -->
  {tools.length > 0 && (
    <section class="container-mast pb-32">
      <header class="section-marker mb-10" data-reveal="fade-up">
        <p class="kicker tabular-nums">04 / 04</p>
        <h2 class="font-display text-3xl sm:text-4xl text-ink-800 tracking-tightest">도구 색인</h2>
        <span class="ml-auto hidden sm:block">
          <a href="/tools/" class="font-mono text-xs tracking-[0.12em] uppercase text-ink-500 hover:text-accent transition-colors">
            모든 도구 →
          </a>
        </span>
      </header>

      <p class="mb-6 max-w-md text-sm text-ink-500 leading-relaxed">
        실험에 등장한 도구들. 클릭하면 해당 도구를 다룬 모든 기록을 볼 수 있다.
      </p>

      <ul class="flex flex-wrap gap-2.5">
        {tools.map((t) => (
          <li>
            <a href={`/tools/${t.slug}/`} class="label-chip">
              <span class="text-ink-800">{t.label}</span>
              <span class="text-accent tabular-nums">{String(t.count).padStart(2, '0')}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}
</BaseLayout>
