---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/post/PostCard.astro';
import ParallaxSection from '../components/layout/ParallaxSection.astro';
import { getAllPosts, postUrl } from '../lib/posts';
import { categoryBuckets, seriesBuckets, toolBuckets } from '../lib/taxonomy';
import { CATEGORY_DESCRIPTIONS, categoryLabel, toSlug } from '../lib/labels';
import { buildPageSeo } from '../lib/seo';
import { SITE_NAME, SITE_TAGLINE, SITE_DESCRIPTION } from '../lib/site';

const posts = await getAllPosts();
const latest = posts.slice(0, 6);
const seriesList = seriesBuckets(posts).slice(0, 3);
const categories = categoryBuckets(posts);
const tools = toolBuckets(posts).slice(0, 8);

const seo = buildPageSeo({
  title: SITE_NAME,
  description: SITE_DESCRIPTION,
  path: '/',
});

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE_NAME,
  url: seo.canonical,
  description: SITE_DESCRIPTION,
  inLanguage: 'ko-KR',
};
---

<BaseLayout seo={seo} jsonLd={websiteJsonLd}>
  <!-- ============================================================
       Hero — full-viewport with gradient mesh + cursor glow
       ============================================================ -->
  <section
    id="hero-glow"
    class="relative flex min-h-[85vh] items-center border-b border-ink-100 bg-gradient-to-b from-accent-soft/30 via-white to-white overflow-hidden"
  >
    <!-- Decorative gradient mesh (static, no JS) -->
    <div class="pointer-events-none absolute inset-0 z-0" aria-hidden="true">
      <div class="absolute -top-32 -right-32 h-96 w-96 rounded-full bg-accent/5 blur-3xl"></div>
      <div class="absolute -bottom-24 -left-24 h-80 w-80 rounded-full bg-accent/3 blur-3xl"></div>
    </div>

    <div class="container-hero relative z-10 py-20 sm:py-28">
      <div class="max-w-3xl">
        <!-- Tagline -->
        <p
          class="text-sm font-semibold uppercase tracking-widest text-accent"
          data-reveal="fade-up"
        >{SITE_TAGLINE}</p>

        <!-- Heading with staggered line breaks -->
        <h1
          class="mt-5 text-4xl font-bold tracking-tight text-ink-900 sm:text-5xl lg:text-display-lg"
          data-reveal="fade-up"
        >
          AI를 써본 결과를<br />그대로 기록한다.
        </h1>

        <!-- Description -->
        <p
          class="mt-6 max-w-xl text-lg leading-relaxed text-ink-500 sm:text-xl"
          data-reveal="fade-up"
          data-reveal-delay="2"
        >
          {SITE_DESCRIPTION}
        </p>

        <!-- CTAs -->
        <div
          class="mt-8 flex flex-wrap gap-3"
          data-reveal="fade-up"
          data-reveal-delay="3"
        >
          <a
            href="/posts/"
            class="inline-flex items-center gap-2 rounded-xl bg-accent px-6 py-3 text-sm font-semibold text-accent-fg shadow-lg shadow-accent/20 transition-colors transition-shadow transition-transform hover:bg-accent/90 hover:shadow-xl hover:shadow-accent/25 hover:-translate-y-0.5 active:translate-y-0"
          >
            글 전체 보기
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a
            href="/about/"
            class="inline-flex items-center gap-2 rounded-xl border border-ink-200 bg-white px-6 py-3 text-sm font-semibold text-ink-700 shadow-sm transition-colors transition-shadow transition-transform hover:border-ink-300 hover:bg-ink-50 hover:shadow-md hover:-translate-y-0.5 active:translate-y-0"
          >
            블로그 소개
          </a>
        </div>
      </div>
    </div>

    <!-- Scroll hint -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10" data-reveal="fade-in" data-reveal-delay="5">
      <div class="flex flex-col items-center gap-2 text-xs text-ink-400">
        <span>스크롤</span>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="animate-bounce"><path d="m6 9 6 6 6-6"/></svg>
      </div>
    </div>
  </section>

  <!-- ============================================================
       Latest Posts
       ============================================================ -->
  <section class="container-wide py-20">
    <div class="flex items-baseline justify-between" data-reveal="fade-up">
      <h2 class="text-2xl font-bold text-ink-900 sm:text-3xl">최신 글</h2>
      <a href="/posts/" class="text-sm font-medium text-accent hover:underline">모두 보기 →</a>
    </div>
    {latest.length === 0 ? (
      <p class="mt-8 rounded-xl border border-dashed border-ink-200 bg-surface p-8 text-center text-sm text-ink-500">
        아직 발행된 글이 없습니다.
      </p>
    ) : (
      <div class="mt-8 grid gap-x-8 gap-y-2 sm:grid-cols-2">
        {latest.map((p) => <PostCard post={p} />)}
      </div>
    )}
  </section>

  <!-- ============================================================
       Recommended Series
       ============================================================ -->
  {seriesList.length > 0 && (
    <ParallaxSection speed={0.15} class="bg-surface py-20">
      <div class="container-wide">
        <div class="flex items-baseline justify-between" data-reveal="fade-up">
          <h2 class="text-2xl font-bold text-ink-900 sm:text-3xl">추천 시리즈</h2>
          <a href="/series/" class="text-sm font-medium text-accent hover:underline">전체 시리즈 →</a>
        </div>
        <ul class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {seriesList.map((s) => (
            <li class="card-elevated p-6 transition-colors transition-shadow transition-transform hover:-translate-y-1 hover:shadow-md">
              <a href={`/series/${s.slug}/`} class="block">
                <p class="text-xs font-semibold uppercase tracking-wide text-ink-400">시리즈 · 글 {s.count}편</p>
                <p class="mt-2 text-xl font-bold text-ink-900 hover:text-accent transition-colors">{s.label}</p>
                <ol class="mt-4 space-y-2 text-sm text-ink-600">
                  {s.posts.slice(0, 3).map((p, i) => (
                    <li class="flex gap-2.5">
                      <span class="text-ink-300 font-medium tabular-nums">{i + 1}.</span>
                      <a href={postUrl(p)} class="hover:text-ink-900 hover:underline transition-colors line-clamp-1">{p.data.title}</a>
                    </li>
                  ))}
                </ol>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </ParallaxSection>
  )}

  <!-- ============================================================
       Category Overview
       ============================================================ -->
  <section class="container-wide py-20">
    <h2 class="text-2xl font-bold text-ink-900 sm:text-3xl" data-reveal="fade-up">카테고리별 대표 글</h2>
    <div class="mt-8 grid gap-6 sm:grid-cols-2">
      {categories.map((c) => (
        <article class="card-elevated p-6 transition-colors transition-shadow transition-transform hover:-translate-y-1 hover:shadow-md">
          <p class="text-xs font-semibold uppercase tracking-wide text-ink-400">카테고리</p>
          <h3 class="mt-2 text-xl font-bold text-ink-900">
            <a href={`/categories/${c.slug}/`} class="hover:text-accent transition-colors">
              {categoryLabel(c.slug)}
            </a>
          </h3>
          <p class="mt-2 text-sm text-ink-500 leading-relaxed">
            {CATEGORY_DESCRIPTIONS[c.slug as keyof typeof CATEGORY_DESCRIPTIONS] ?? ''}
          </p>
          <ul class="mt-4 space-y-1.5 text-sm">
            {c.posts.slice(0, 3).map((p) => (
              <li>
                <a href={postUrl(p)} class="text-ink-600 hover:text-ink-900 hover:underline transition-colors">
                  {p.data.title}
                </a>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <!-- ============================================================
       Tools Overview
       ============================================================ -->
  {tools.length > 0 && (
    <section class="container-wide pb-24">
      <div class="flex items-baseline justify-between" data-reveal="fade-up">
        <h2 class="text-2xl font-bold text-ink-900 sm:text-3xl">도구별 글 모음</h2>
        <a href="/tools/" class="text-sm font-medium text-accent hover:underline">모든 도구 →</a>
      </div>
      <ul class="mt-8 flex flex-wrap gap-3">
        {tools.map((t) => (
          <li>
            <a
              href={`/tools/${t.slug}/`}
              class="inline-flex items-center gap-2.5 rounded-full border border-ink-200 bg-white px-4 py-2.5 text-sm font-medium text-ink-700 shadow-sm transition-colors transition-shadow transition-transform hover:border-accent hover:text-accent hover:shadow-md hover:-translate-y-0.5 active:translate-y-0"
            >
              <span>{t.label}</span>
              <span class="rounded-full bg-ink-100 px-2 py-0.5 text-xs font-medium text-ink-500">{t.count}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}
</BaseLayout>
