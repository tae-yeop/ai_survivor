---
import BaseLayout from './BaseLayout.astro';
import ScrollProgress from '../components/layout/ScrollProgress.astro';
import Breadcrumbs from '../components/post/Breadcrumbs.astro';
import PostMeta from '../components/post/PostMeta.astro';
import TableOfContents from '../components/post/TableOfContents.astro';
import RelatedPosts from '../components/post/RelatedPosts.astro';
import SeriesNav from '../components/post/SeriesNav.astro';
import AuthorBox from '../components/post/AuthorBox.astro';
import AdSlot from '../components/ads/AdSlot.astro';
import type { Post } from '../lib/posts';
import type { SeoMeta } from '../lib/seo';
import { categoryLabel, toSlug } from '../lib/labels';
import { formatIso } from '../lib/dates';

interface Heading { depth: number; slug: string; text: string }

interface Props {
  post: Post;
  seo: SeoMeta;
  jsonLd: unknown;
  headings: Heading[];
  related: Post[];
  prev?: Post;
  next?: Post;
  readingMinutes: number;
}

const { post, seo, jsonLd, headings, related, prev, next, readingMinutes } = Astro.props;
const { data } = post;

const breadcrumbs = [
  { href: '/', label: 'Home' },
  { href: '/posts/', label: 'Posts' },
  { href: `/categories/${data.category}/`, label: categoryLabel(data.category) },
  { label: data.title },
];

const dateIso = formatIso(data.publishedAt);
const dateLabel = `${data.publishedAt.getFullYear()}.${String(data.publishedAt.getMonth() + 1).padStart(2, '0')}.${String(data.publishedAt.getDate()).padStart(2, '0')}`;
---

<BaseLayout seo={seo} jsonLd={jsonLd} showPreloader={false}>
  <ScrollProgress />

  <article class="container-mast pt-8 pb-20">
    <div class="mb-10" data-reveal="fade-down">
      <Breadcrumbs items={breadcrumbs} />
    </div>

    <!-- ============================================================
         Article header — kicker, serif title, lede, mono meta strip
         ============================================================ -->
    <header class="mx-auto max-w-3xl">
      <div class="flex items-center gap-3" data-reveal="fade-up">
        <span class="kicker kicker-accent">
          <a href={`/categories/${data.category}/`} class="hover:underline underline-offset-4">
            {categoryLabel(data.category)}
          </a>
        </span>
        <span aria-hidden="true" class="block h-px w-12 bg-paper-rule"></span>
        <time datetime={dateIso} class="font-mono text-xs text-ink-500 tabular-nums">{dateLabel}</time>
      </div>

      <h1
        class="mt-5 font-display text-display-lg text-ink-800 leading-[1.05] tracking-tightest text-balance"
        data-reveal="fade-up"
        data-reveal-delay="1"
      >
        {data.title}
      </h1>

      <p
        class="mt-6 text-lg sm:text-xl text-ink-600 leading-relaxed max-w-2xl text-pretty"
        data-reveal="fade-up"
        data-reveal-delay="2"
      >
        {data.description}
      </p>

      <div
        class="mt-8 pt-5 border-t border-ink-800"
        data-reveal="fade-up"
        data-reveal-delay="3"
      >
        <PostMeta post={post} readingMinutes={readingMinutes} />
      </div>

      {data.tools && data.tools.length > 0 && (
        <ul class="mt-5 flex flex-wrap gap-2" data-reveal="fade-up" data-reveal-delay="3">
          {data.tools.map((tool) => (
            <li>
              <a href={`/tools/${toSlug(tool)}/`} class="label-chip">
                <span class="text-ink-400">tool</span>
                <span>{tool}</span>
              </a>
            </li>
          ))}
        </ul>
      )}

      {typeof data.coverImage === 'string' && data.coverImage && (
        <figure class="mt-12 border border-paper-rule overflow-hidden" data-reveal="fade-in" data-reveal-delay="4">
          <img src={data.coverImage} alt={data.coverAlt ?? ''} loading="eager" class="w-full" />
          {data.coverAlt && (
            <figcaption class="border-t border-paper-rule px-5 py-3 font-mono text-xs text-ink-500">
              FIG. — {data.coverAlt}
            </figcaption>
          )}
        </figure>
      )}
    </header>

    <!-- ============================================================
         Body grid — content + sticky ToC sidebar (xl+)
         ============================================================ -->
    <div class="mx-auto mt-16 grid max-w-5xl gap-x-14 xl:grid-cols-[minmax(0,1fr)_220px]">
      <div class="min-w-0">
        <div class="xl:hidden mb-8">
          <TableOfContents headings={headings} />
        </div>

        <div class="prose prose-lg max-w-none drop-cap">
          <slot />
        </div>

        <AdSlot label="post-bottom" class="mt-16" />

        <div class="mt-16">
          <SeriesNav series={data.series ?? null} prev={prev} next={next} />
        </div>

        {data.tags.length > 0 && (
          <section class="mt-16 pt-6 border-t border-ink-800">
            <p class="kicker mb-4">filed under</p>
            <ul class="flex flex-wrap gap-2">
              {data.tags.map((tag) => (
                <li>
                  <a href={`/tags/${toSlug(tag)}/`} class="label-chip">
                    <span class="text-accent">#</span>
                    <span>{tag}</span>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        )}

        <div class="mt-16">
          <AuthorBox authorKey={data.author} />
        </div>

        <div class="mt-16">
          <RelatedPosts posts={related} />
        </div>
      </div>

      <aside class="hidden xl:block">
        <div class="sticky top-28">
          <TableOfContents headings={headings} />
        </div>
      </aside>
    </div>
  </article>
</BaseLayout>
