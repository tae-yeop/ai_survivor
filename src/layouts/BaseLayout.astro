---
import '../styles/global.css';
import SeoHead from '../components/seo/SeoHead.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Preloader from '../components/layout/Preloader.astro';
import type { SeoMeta } from '../lib/seo';
import { SITE_LANG } from '../lib/site';

interface Props {
  seo: SeoMeta;
  jsonLd?: unknown;
  bodyClass?: string;
  showPreloader?: boolean;
}

const { seo, jsonLd, bodyClass, showPreloader = true } = Astro.props;
---

<!doctype html>
<html lang={SITE_LANG}>
  <head>
    <SeoHead seo={seo} jsonLd={jsonLd} />

    <!-- Theme FOUC prevention — runs before first paint -->
    <script is:inline>
      (function() {
        const stored = localStorage.getItem('theme');
        if (stored === 'dark' || (!stored && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>

    <slot name="head" />
  </head>
  <body class:list={['min-h-screen flex flex-col', bodyClass]}>
    {showPreloader && <Preloader />}
    <a href="#main" class="skip-link">본문으로 건너뛰기</a>
    <Header />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer />
    <script src="/scripts/motion.js" defer></script>
  </body>
</html>
