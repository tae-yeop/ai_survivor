---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/post/Breadcrumbs.astro';
import type { SeoMeta } from '../lib/seo';

interface Crumb { href?: string; label: string }

interface Props {
  seo: SeoMeta;
  jsonLd?: unknown;
  title: string;
  description?: string;
  breadcrumbs?: Crumb[];
  kicker?: string;
  count?: number;
  countLabel?: string;
}

const {
  seo,
  jsonLd,
  title,
  description,
  breadcrumbs,
  kicker,
  count,
  countLabel = '편',
} = Astro.props;
---

<BaseLayout seo={seo} jsonLd={jsonLd}>
  <div class="container-mast pt-8 pb-16">
    {breadcrumbs && breadcrumbs.length > 0 && (
      <div class="mb-10"><Breadcrumbs items={breadcrumbs} /></div>
    )}

    <header class="grid gap-y-6 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-end lg:gap-x-12 pb-8 border-b border-ink-800">
      <div>
        {kicker && <p class="kicker kicker-accent">{kicker}</p>}
        <h1 class="mt-3 font-display text-display text-ink-800 leading-[1.05] tracking-tightest text-balance">
          {title}
        </h1>
        {description && (
          <p class="mt-5 max-w-2xl text-ink-500 leading-relaxed text-pretty">{description}</p>
        )}
      </div>

      {typeof count === 'number' && (
        <aside class="flex items-baseline gap-3 lg:flex-col lg:items-end lg:gap-1 lg:pb-2">
          <p class="font-display text-5xl text-ink-800 leading-none tabular-nums">
            {String(count).padStart(2, '0')}
          </p>
          <p class="kicker tabular-nums">{countLabel}</p>
        </aside>
      )}
    </header>

    <div class="mt-10">
      <slot />
    </div>
  </div>
</BaseLayout>
