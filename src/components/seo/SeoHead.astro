---
import type { SeoMeta } from '../../lib/seo';
import {
  SITE_NAME,
  SITE_LOCALE,
  SITE_LANG,
  ADS_ENABLED,
  ADSENSE_CLIENT,
} from '../../lib/site';

interface Props {
  seo: SeoMeta;
  jsonLd?: unknown;
}

const { seo, jsonLd } = Astro.props;
const fullTitle =
  seo.title === SITE_NAME ? seo.title : `${seo.title} · ${SITE_NAME}`;
const robots = seo.noindex ? 'noindex,nofollow' : 'index,follow';
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
<meta name="generator" content={Astro.generator} />
<title>{fullTitle}</title>
<meta name="description" content={seo.description} />
<meta name="robots" content={robots} />
<link rel="canonical" href={seo.canonical} />
<link rel="alternate" type="application/rss+xml" title={`${SITE_NAME} RSS`} href="/rss.xml" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

{seo.author && <meta name="author" content={seo.author} />}
{seo.keywords && seo.keywords.length > 0 && (
  <meta name="keywords" content={seo.keywords.join(', ')} />
)}

<meta property="og:type" content={seo.ogType} />
<meta property="og:title" content={seo.title} />
<meta property="og:description" content={seo.description} />
<meta property="og:url" content={seo.canonical} />
<meta property="og:site_name" content={SITE_NAME} />
<meta property="og:locale" content={SITE_LOCALE} />
<meta property="og:image" content={seo.ogImage} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={seo.title} />
<meta name="twitter:description" content={seo.description} />
<meta name="twitter:image" content={seo.ogImage} />

{seo.publishedAt && <meta property="article:published_time" content={seo.publishedAt} />}
{seo.updatedAt && <meta property="article:modified_time" content={seo.updatedAt} />}

<meta http-equiv="content-language" content={SITE_LANG} />

{jsonLd && (
  <script
    type="application/ld+json"
    set:html={JSON.stringify(jsonLd)}
  />
)}

{ADS_ENABLED && ADSENSE_CLIENT && (
  <script
    async
    src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${ADSENSE_CLIENT}`}
    crossorigin="anonymous"
  ></script>
)}
