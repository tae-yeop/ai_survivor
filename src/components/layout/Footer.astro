---
import { NAV_FOOTER, SITE_NAME, SITE_TAGLINE } from '../../lib/site';

const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-ink-100 bg-surface">
  <div class="container-wide py-14">
    <div class="flex flex-col gap-10 sm:flex-row sm:items-start sm:justify-between">
      <!-- Brand column -->
      <div class="max-w-xs">
        <a href="/" class="text-lg font-bold tracking-tight text-ink-900 hover:text-accent transition-colors">
          {SITE_NAME}
        </a>
        <p class="mt-2 text-sm text-ink-500 leading-relaxed">{SITE_TAGLINE}</p>
        <!-- Social / connect links -->
        <div class="mt-4 flex items-center gap-3">
          <a href="/rss.xml" class="rounded-full bg-ink-100 p-2 text-ink-500 hover:bg-ink-200 hover:text-ink-700 transition-colors" aria-label="RSS 피드">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
          </a>
          <a href="mailto:hello@example.com" class="rounded-full bg-ink-100 p-2 text-ink-500 hover:bg-ink-200 hover:text-ink-700 transition-colors" aria-label="이메일">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          </a>
        </div>
      </div>

      <!-- Nav columns -->
      <div class="flex flex-wrap gap-x-16 gap-y-8">
        <div>
          <p class="text-xs font-semibold uppercase tracking-wider text-ink-400">탐색</p>
          <ul class="mt-3 space-y-2 text-sm text-ink-600">
            <li><a href="/posts/" class="hover:text-ink-900 hover:underline transition-colors">글 전체</a></li>
            <li><a href="/categories/" class="hover:text-ink-900 hover:underline transition-colors">카테고리</a></li>
            <li><a href="/series/" class="hover:text-ink-900 hover:underline transition-colors">시리즈</a></li>
            <li><a href="/tags/" class="hover:text-ink-900 hover:underline transition-colors">태그</a></li>
            <li><a href="/tools/" class="hover:text-ink-900 hover:underline transition-colors">도구</a></li>
          </ul>
        </div>
        <div>
          <p class="text-xs font-semibold uppercase tracking-wider text-ink-400">정보</p>
          <ul class="mt-3 space-y-2 text-sm text-ink-600">
            {NAV_FOOTER.map((item) => (
              <li><a href={item.href} class="hover:text-ink-900 hover:underline transition-colors">{item.label}</a></li>
            ))}
          </ul>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 flex flex-col gap-2 border-t border-ink-100 pt-6 text-xs text-ink-400 sm:flex-row sm:items-center sm:justify-between">
      <p>&copy; {year} {SITE_NAME}. All rights reserved.</p>
      <a href="#main" class="inline-flex items-center gap-1 hover:text-ink-600 transition-colors">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m18 15-6-6-6 6"/></svg>
        맨 위로
      </a>
    </div>
  </div>
</footer>
