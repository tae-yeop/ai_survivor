---
// Theme toggle — sun/moon icon, localStorage persistence, prefers-color-scheme.
// FOUC prevention: init script in BaseLayout <head> runs before paint.
---

<button
  id="theme-toggle"
  class="grid place-items-center h-9 w-9 border border-paper-rule text-ink-500 hover:text-accent hover:border-ink-800 transition-colors"
  aria-label="다크 모드 전환"
  title="밝은/어두운 테마 전환"
>
  <svg id="theme-icon-sun" class="hidden" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
    <circle cx="12" cy="12" r="4"/>
    <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>
  </svg>
  <svg id="theme-icon-moon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
  </svg>
</button>

<script>
  (function () {
    const toggle = document.getElementById('theme-toggle');
    const sunIcon = document.getElementById('theme-icon-sun');
    const moonIcon = document.getElementById('theme-icon-moon');
    if (!toggle || !sunIcon || !moonIcon) return;

    const html = document.documentElement;

    function updateIcons() {
      const isDark = html.classList.contains('dark');
      sunIcon.classList.toggle('hidden', !isDark);
      moonIcon.classList.toggle('hidden', isDark);
      toggle.setAttribute('aria-label', isDark ? '밝은 모드로 전환' : '어두운 모드로 전환');
    }

    toggle.addEventListener('click', () => {
      const isDark = html.classList.toggle('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
      updateIcons();
    });

    updateIcons();
  })();
</script>
