<!-- Editorial preloader — masthead splash, removed by motion.js.
     Hidden immediately if JS is disabled or the user prefers reduced motion. -->
<div
  id="preloader"
  class="fixed inset-0 z-50 flex items-center justify-center bg-bg-primary"
  style="transition: opacity 0.45s ease, visibility 0.45s ease;"
>
  <div class="flex flex-col items-center gap-5 text-center">
    <span class="kicker kicker-accent">An editorial lab journal · est. 2026</span>
    <p class="font-display font-bold text-4xl sm:text-5xl text-ink-800 leading-none tracking-[-0.025em]">
      AI <span class="text-accent">Vibe</span> Lab
    </p>
    <div class="mt-1 flex items-center gap-3">
      <span class="block h-px w-10 bg-paper-rule"></span>
      <span class="kicker animate-pulse-soft">loading the press</span>
      <span class="block h-px w-10 bg-paper-rule"></span>
    </div>
  </div>
</div>

<noscript>
  <style>
    /* No JS = no animations = no need for the splash. Hide immediately. */
    #preloader { display: none !important; }
  </style>
</noscript>

<style is:global>
  .preloader-hidden {
    opacity: 0 !important;
    visibility: hidden !important;
    pointer-events: none !important;
  }
  /* Users who disable motion still get the page, not a permanent splash. */
  @media (prefers-reduced-motion: reduce) {
    #preloader { display: none !important; }
  }
</style>
