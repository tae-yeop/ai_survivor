---
import { ADS_ENABLED, ADSENSE_CLIENT } from '../../lib/site';

interface Props {
  slot?: string;
  format?: string;
  responsive?: boolean;
  label?: string;
  class?: string;
}

const {
  slot,
  format = 'auto',
  responsive = true,
  label = 'Ad',
  class: className,
} = Astro.props;

const enabled = ADS_ENABLED && ADSENSE_CLIENT && slot;
const showPlaceholder = !enabled && import.meta.env.DEV;
---

{enabled && (
  <div class:list={['ad-slot', className]} data-ads>
    <ins
      class="adsbygoogle"
      style="display:block"
      data-ad-client={ADSENSE_CLIENT}
      data-ad-slot={slot}
      data-ad-format={format}
      data-full-width-responsive={responsive ? 'true' : 'false'}
    ></ins>
    <script set:html={`(adsbygoogle = window.adsbygoogle || []).push({});`} />
  </div>
)}

{showPlaceholder && (
  <aside
    class:list={[
      'ad-slot border-y border-ink-800 py-10 grid place-items-center text-center',
      className,
    ]}
    aria-hidden="true"
    data-ads
  >
    <p class="font-mono text-[0.7rem] tracking-[0.2em] uppercase text-ink-400">— Advertisement —</p>
    <p class="mt-2 font-mono text-sm text-ink-500">
      {label} · 승인 후 활성화
    </p>
  </aside>
)}
