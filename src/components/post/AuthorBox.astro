---
import { getAuthor } from '../../lib/authors';

interface Props {
  authorKey: string;
}

const { authorKey } = Astro.props;
const author = getAuthor(authorKey);
---

<aside class="grid gap-4 sm:grid-cols-[auto_1fr] sm:gap-7 border-t-2 border-b border-ink-800 py-8">
  <div class="flex items-center gap-4 sm:flex-col sm:items-start sm:gap-3">
    <div
      class="flex h-14 w-14 shrink-0 items-center justify-center bg-ink-800 text-paper font-display font-bold text-2xl"
      aria-hidden="true"
    >
      {author.name.slice(0, 1)}
    </div>
    <p class="kicker">written by</p>
  </div>
  <div>
    <p class="font-display text-2xl text-ink-800 leading-tight tracking-tight">{author.name}</p>
    <p class="mt-2 text-ink-600 leading-relaxed max-w-prose">{author.bio}</p>
    {author.url && (
      <a
        href={author.url}
        class="mt-4 inline-flex items-center gap-2 font-mono text-[0.7rem] tracking-[0.12em] uppercase text-accent border-b border-accent/40 hover:border-accent pb-0.5"
      >
        소개 더 보기
        <span aria-hidden="true">↗</span>
      </a>
    )}
  </div>
</aside>
