---
import { getAuthor } from '../../lib/authors';

interface Props {
  authorKey: string;
}

const { authorKey } = Astro.props;
const author = getAuthor(authorKey);
---

<aside class="flex items-start gap-5 rounded-xl border border-ink-100 bg-white p-6 shadow-sm">
  <div
    class="flex h-14 w-14 shrink-0 items-center justify-center rounded-full bg-accent-soft text-xl font-bold text-accent"
    aria-hidden="true"
  >
    {author.name.slice(0, 1)}
  </div>
  <div>
    <p class="text-lg font-bold text-ink-900">{author.name}</p>
    <p class="mt-1.5 text-sm text-ink-500 leading-relaxed">{author.bio}</p>
    {author.url && (
      <a
        href={author.url}
        class="mt-3 inline-flex items-center gap-1 text-sm font-medium text-accent hover:underline"
      >
        소개 더 보기
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    )}
  </div>
</aside>
