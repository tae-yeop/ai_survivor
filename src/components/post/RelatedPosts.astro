---
import type { Post } from '../../lib/posts';
import { postUrl } from '../../lib/posts';
import { categoryLabel } from '../../lib/labels';
import { formatDate, formatIso } from '../../lib/dates';

interface Props {
  posts: Post[];
}

const { posts } = Astro.props;
---

{posts.length > 0 && (
  <section aria-labelledby="related-posts" class="pt-10 border-t border-ink-800">
    <header class="flex items-baseline justify-between gap-4 mb-6">
      <p class="kicker kicker-accent">further reading</p>
      <h2 id="related-posts" class="font-display text-2xl text-ink-800 tracking-[-0.025em]">관련 기록</h2>
    </header>

    <ul class="grid gap-x-10 sm:grid-cols-2 divide-hair sm:divide-none">
      {posts.map((p, i) => (
        <li class:list={[
          'py-6 sm:py-0 sm:border-t sm:border-paper-rule sm:pt-6',
          i >= 2 && 'sm:mt-6',
        ]}>
          <a href={postUrl(p)} class="group block">
            <div class="flex items-center gap-3">
              <span class="kicker kicker-accent">{categoryLabel(p.data.category)}</span>
              <span aria-hidden="true" class="text-paper-rule">·</span>
              <time
                datetime={formatIso(p.data.publishedAt)}
                class="font-mono text-[0.7rem] text-ink-500 tabular-nums"
              >
                {formatDate(p.data.publishedAt)}
              </time>
            </div>
            <p class="mt-2 font-display text-xl text-ink-800 leading-snug tracking-tight group-hover:text-accent transition-colors text-balance">
              {p.data.title}
            </p>
            <p class="mt-2 text-sm text-ink-500 leading-relaxed line-clamp-2">
              {p.data.description}
            </p>
          </a>
        </li>
      ))}
    </ul>
  </section>
)}
