---
import type { Post } from '../../lib/posts';
import { postUrl } from '../../lib/posts';
import { categoryLabel } from '../../lib/labels';

interface Props {
  posts: Post[];
}

const { posts } = Astro.props;
---

{posts.length > 0 && (
  <section aria-labelledby="related-posts" class="border-t border-ink-100 pt-10">
    <h2 id="related-posts" class="text-xl font-bold text-ink-900">
      관련 글
    </h2>
    <ul class="mt-5 grid gap-4 sm:grid-cols-2">
      {posts.map((p) => (
        <li>
          <a
            href={postUrl(p)}
            class="block rounded-xl border border-ink-100 bg-white p-5 shadow-sm transition-colors transition-shadow transition-transform hover:-translate-y-1 hover:border-ink-200 hover:shadow-md"
          >
            <p class="text-xs font-medium text-accent">{categoryLabel(p.data.category)}</p>
            <p class="mt-2 font-bold text-ink-900 leading-snug">{p.data.title}</p>
            <p class="mt-1.5 text-sm text-ink-500 leading-relaxed line-clamp-2">{p.data.description}</p>
          </a>
        </li>
      ))}
    </ul>
  </section>
)}
