---
import type { Post } from '../../lib/posts';
import { difficultyLabel } from '../../lib/labels';
import { formatDate, formatIso } from '../../lib/dates';

interface Props {
  post: Post;
  readingMinutes?: number;
}

const { post, readingMinutes } = Astro.props;
const { data } = post;
const updatedDiffers = data.updatedAt.toDateString() !== data.publishedAt.toDateString();
---

<dl class="flex flex-wrap items-center gap-x-5 gap-y-2 font-mono text-[0.72rem] tracking-[0.04em] text-ink-500 tabular-nums">
  <div class="flex items-center gap-2">
    <dt class="kicker text-ink-400">PUB</dt>
    <dd>
      <time datetime={formatIso(data.publishedAt)}>{formatDate(data.publishedAt)}</time>
    </dd>
  </div>

  {updatedDiffers && (
    <div class="flex items-center gap-2">
      <dt class="kicker text-ink-400">REV</dt>
      <dd>
        <time datetime={formatIso(data.updatedAt)}>{formatDate(data.updatedAt)}</time>
      </dd>
    </div>
  )}

  <div class="flex items-center gap-2">
    <dt class="kicker text-ink-400">LV</dt>
    <dd class="text-ink-700">{difficultyLabel(data.difficulty)}</dd>
  </div>

  {readingMinutes && (
    <div class="flex items-center gap-2">
      <dt class="kicker text-ink-400">RT</dt>
      <dd>{readingMinutes}분 읽기</dd>
    </div>
  )}
</dl>
