---
interface Crumb {
  href?: string;
  label: string;
}

interface Props {
  items: Crumb[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="text-sm">
  <ol class="flex flex-wrap items-center gap-1.5">
    {items.map((item, i) => (
      <li class="flex items-center gap-1.5">
        {item.href ? (
          <a href={item.href} class="text-ink-400 hover:text-ink-700 hover:underline transition-colors">
            {item.label}
          </a>
        ) : (
          <span aria-current="page" class="font-medium text-ink-700">{item.label}</span>
        )}
        {i < items.length - 1 && (
          <svg aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-ink-300"><path d="m9 18 6-6-6-6"/></svg>
        )}
      </li>
    ))}
  </ol>
</nav>
