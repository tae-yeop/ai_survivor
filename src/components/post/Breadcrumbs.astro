---
interface Crumb {
  href?: string;
  label: string;
}

interface Props {
  items: Crumb[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb">
  <ol class="flex flex-wrap items-center gap-x-2 gap-y-1 font-mono text-[0.7rem] tracking-[0.08em] uppercase">
    {items.map((item, i) => (
      <li class="flex items-center gap-2">
        {item.href ? (
          <a href={item.href} class="text-ink-400 hover:text-accent transition-colors">
            {item.label}
          </a>
        ) : (
          <span aria-current="page" class="text-ink-700 max-w-[28ch] truncate normal-case tracking-normal">
            {item.label}
          </span>
        )}
        {i < items.length - 1 && (
          <span aria-hidden="true" class="text-paper-rule">/</span>
        )}
      </li>
    ))}
  </ol>
</nav>
