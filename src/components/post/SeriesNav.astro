---
import type { Post } from '../../lib/posts';
import { postUrl } from '../../lib/posts';
import { toSlug } from '../../lib/labels';

interface Props {
  series: string | null | undefined;
  prev?: Post;
  next?: Post;
}

const { series, prev, next } = Astro.props;
---

{series && (prev || next) && (
  <section
    aria-labelledby="series-nav"
    class="rounded-xl border border-ink-100 bg-surface p-6"
  >
    <div class="flex items-center gap-2">
      <span class="rounded-full bg-accent-soft px-2.5 py-0.5 text-xs font-semibold text-accent uppercase tracking-wider">시리즈</span>
    </div>
    <h2 id="series-nav" class="mt-3 text-lg font-bold text-ink-900">
      <a href={`/series/${toSlug(series)}/`} class="hover:text-accent transition-colors">{series}</a>
    </h2>
    <div class="mt-5 grid gap-3 sm:grid-cols-2">
      {prev ? (
        <a
          href={postUrl(prev)}
          rel="prev"
          class="group block rounded-xl border border-ink-100 bg-white p-4 shadow-sm transition-all hover:-translate-y-0.5 hover:shadow-md"
        >
          <p class="text-xs font-medium text-ink-400 flex items-center gap-1">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m15 18-6-6 6-6"/></svg>
            이전 글
          </p>
          <p class="mt-1.5 text-sm font-semibold text-ink-900 group-hover:text-accent transition-colors leading-snug">{prev.data.title}</p>
        </a>
      ) : <span class="hidden sm:block" aria-hidden="true"></span>}
      {next ? (
        <a
          href={postUrl(next)}
          rel="next"
          class="group block rounded-xl border border-ink-100 bg-white p-4 text-right shadow-sm transition-all hover:-translate-y-0.5 hover:shadow-md"
        >
          <p class="text-xs font-medium text-ink-400 flex items-center justify-end gap-1">
            다음 글
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
          </p>
          <p class="mt-1.5 text-sm font-semibold text-ink-900 group-hover:text-accent transition-colors leading-snug">{next.data.title}</p>
        </a>
      ) : <span class="hidden sm:block" aria-hidden="true"></span>}
    </div>
  </section>
)}
