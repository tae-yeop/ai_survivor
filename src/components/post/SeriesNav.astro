---
import type { Post } from '../../lib/posts';
import { postUrl } from '../../lib/posts';
import { toSlug, seriesLabel } from '../../lib/labels';

interface Props {
  series: string | null | undefined;
  prev?: Post;
  next?: Post;
}

const { series, prev, next } = Astro.props;
const label = series ? seriesLabel(series) : '';
---

{series && (prev || next) && (
  <section
    aria-labelledby="series-nav"
    class="border-t-2 border-b border-ink-800 py-7"
  >
    <div class="flex items-baseline gap-3">
      <p class="kicker kicker-accent">series</p>
      <span aria-hidden="true" class="block h-px flex-1 bg-paper-rule"></span>
    </div>
    <h2 id="series-nav" class="mt-2 font-display text-2xl text-ink-800 leading-tight tracking-[-0.025em]">
      <a href={`/series/${toSlug(series)}/`} class="hover:text-accent transition-colors">
        {label}
      </a>
    </h2>

    <div class="mt-6 grid gap-px sm:grid-cols-2 bg-paper-rule">
      {prev ? (
        <a
          href={postUrl(prev)}
          rel="prev"
          class="group block bg-bg-primary p-5 transition-colors hover:bg-paper-deep"
        >
          <p class="kicker flex items-center gap-1.5">
            <span aria-hidden="true">←</span>
            이전 호
          </p>
          <p class="mt-2 font-display text-lg text-ink-800 group-hover:text-accent transition-colors leading-snug line-clamp-2">
            {prev.data.title}
          </p>
        </a>
      ) : <div class="hidden sm:block bg-bg-primary" aria-hidden="true"></div>}

      {next ? (
        <a
          href={postUrl(next)}
          rel="next"
          class="group block bg-bg-primary p-5 text-right transition-colors hover:bg-paper-deep"
        >
          <p class="kicker flex items-center justify-end gap-1.5">
            다음 호
            <span aria-hidden="true">→</span>
          </p>
          <p class="mt-2 font-display text-lg text-ink-800 group-hover:text-accent transition-colors leading-snug line-clamp-2">
            {next.data.title}
          </p>
        </a>
      ) : <div class="hidden sm:block bg-bg-primary" aria-hidden="true"></div>}
    </div>
  </section>
)}
