# Public site URL used for canonical URLs, sitemap, RSS, and Open Graph.
NEXT_PUBLIC_SITE_URL="https://aivibelab.com"

# Ads are disabled until AdSense approval.
ADS_ENABLED="false"
ADSENSE_CLIENT=""

# ADR-003 MVP note:
# Supabase/Auth/Admin CMS keys are intentionally not required.
# Add provider-specific env vars only after a new ADR reactivates that path.

# Optional Phase B admin editor. Keep all values server-only in Vercel.
# GitHub OAuth callback URL: https://aivibelab.com/api/admin/github/callback
ADMIN_GITHUB_LOGIN=""
# Optional stable owner check. Copy from GitHub user API if you want login rename protection.
ADMIN_GITHUB_ID=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
# 32+ random chars. Example generator: openssl rand -base64 32
ADMIN_SESSION_SECRET=""

# Fine-grained GitHub token with Contents read/write access to this repository.
GITHUB_CONTENT_TOKEN=""
GITHUB_REPO="tae-yeop/ai_survivor"
GITHUB_BRANCH="master"

# Cloudflare R2 for video/media uploads (Phase 5 — slice-5.3).
# Create a bucket in Cloudflare dashboard → R2 → Create bucket.
# Generate an R2 API token with Object Read & Write, then copy the S3-compatible credentials.
# R2_PUBLIC_URL: public domain from r2.dev subdomain or a custom domain on the bucket.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_URL=""
